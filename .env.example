# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=postgresql://admin:admin@localhost:5432/monitoring?schema=public

# ── Backend ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Auth (configurar en sprint de autenticación) ──────────────
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── SMTP Configuration (e.g. Mailpit/Mailhog for local dev, real provider for prod) ──
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@ugel-lampa.gob.pe