generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. GESTIÓN DE ROLES E IDENTIDAD CENTRAL
// ==========================================

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  users       User[]

  @@map("roles")
}

model Persona {
  id          String   @id @default(uuid()) @db.Uuid
  dni         String   @unique @db.VarChar(8)
  nombres     String   @db.VarChar(120)
  apellidos   String   @db.VarChar(120)
  correo      String?  @unique @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user        User?
  especialista Especialista?
  docente     Docente?

  @@map("personas")
}

// ==========================================
// 2. IDENTIDAD DIGITAL Y SEGURIDAD (AUTH)
// ==========================================

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  personaId            String    @unique @map("persona_id") @db.Uuid
  roleId               String    @map("role_id") @db.Uuid
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  isActive             Boolean   @default(true) @map("is_active")
  isFirstLogin         Boolean   @default(true) @map("is_first_login")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  lastLoginAt          DateTime? @map("last_login_at")
  lastFailedLoginAt    DateTime? @map("last_failed_login_at")
  passwordChangedAt    DateTime? @map("password_changed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  persona              Persona               @relation(fields: [personaId], references: [id])
  role                 Role                  @relation(fields: [roleId], references: [id])
  authSessions         AuthSession[]
  passwordResetTokens  PasswordResetToken[]
  authAuditLogs        AuthAuditLog[]

  @@index([personaId])
  @@index([roleId])
  @@index([isActive])
  @@index([lockedUntil])
  @@map("users")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  sessionJti       String    @unique @map("session_jti") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(500)
  startedAt        DateTime  @default(now()) @map("started_at")
  lastActivityAt   DateTime  @default(now()) @map("last_activity_at")
  expiresAt        DateTime  @map("expires_at")
  loggedOutAt      DateTime? @map("logged_out_at")
  terminatedReason String?   @map("terminated_reason") @db.VarChar(30)
  isActive         Boolean   @default(true) @map("is_active")

  user             User      @relation(fields: [userId], references: [id])

  @@index([sessionJti])
  @@index([userId, isActive])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at")
  isUsed      Boolean   @default(false) @map("is_used")
  usedAt      DateTime? @map("used_at")
  requestedIp String?   @map("requested_ip") @db.VarChar(64)
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AuthAuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  eventType   String    @map("event_type") @db.VarChar(80)
  eventDetail String?   @map("event_detail") @db.Text
  ipAddress   String?   @map("ip_address") @db.VarChar(64)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt])
  @@map("auth_audit_logs")
}

// ==========================================
// 3. MÓDULOS DE NEGOCIO: UGEL Y COLEGIOS
// ==========================================

model InstitucionEducativa {
  id             String   @id @default(uuid()) @db.Uuid
  codigoModular  String   @unique @map("codigo_modular") @db.VarChar(7)
  nombre         String   @db.VarChar(100)
  nivelEducativo String   @map("nivel_educativo") @db.VarChar(50)
  departamento   String   @default("Puno") @db.VarChar(50)
  provincia      String   @db.VarChar(50)
  distrito       String   @db.VarChar(50)
  direccion      String   @db.VarChar(150)
  zona           String   @db.VarChar(20)
  estado         String   @default("Activa") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  docentes       Docente[]

  @@map("instituciones_educativas")
}

model Especialista {
  id             String   @id @default(uuid()) @db.Uuid
  personaId      String   @unique @map("persona_id") @db.Uuid
  especialidad   String   @db.VarChar(100)
  nivelEducativo String   @map("nivel_educativo") @db.VarChar(50)
  estado         String   @default("Activo") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  persona        Persona  @relation(fields: [personaId], references: [id])

  @@map("especialistas")
}

model Docente {
  id             String   @id @default(uuid()) @db.Uuid
  personaId      String   @unique @map("persona_id") @db.Uuid
  institucionId  String   @map("institucion_id") @db.Uuid
  gradoAcademico String?  @map("grado_academico") @db.VarChar(50)
  nivelEducativo String   @map("nivel_educativo") @db.VarChar(50)
  cursoAsignado  String?  @map("curso_asignado") @db.VarChar(150)
  estado         String   @default("Activo") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  persona        Persona  @relation(fields: [personaId], references: [id])
  institucion    InstitucionEducativa @relation(fields: [institucionId], references: [id])
  docenteCargos  DocenteCargo[]

  @@index([institucionId])
  @@map("docentes")
}

// ==========================================
// 4. HISTORIAL Y GESTIÓN DE CARGOS
// ==========================================

model Cargo {
  id            String   @id @default(uuid()) @db.Uuid
  nombre        String   @unique @db.VarChar(50)
  docenteCargos DocenteCargo[]

  @@map("cargos")
}

model DocenteCargo {
  id          String    @id @default(uuid()) @db.Uuid
  docenteId   String    @map("docente_id") @db.Uuid
  cargoId     String    @map("cargo_id") @db.Uuid
  fechaInicio DateTime  @default(now()) @map("fecha_inicio")
  fechaFin    DateTime? @map("fecha_fin")

  docente     Docente   @relation(fields: [docenteId], references: [id])
  cargo       Cargo     @relation(fields: [cargoId], references: [id])

  @@index([docenteId, cargoId, fechaInicio])
  @@map("docente_cargos")
}